---
import "@styles/contacto.scss";

const email = "contacto@barcodesgenerator.com";
---

<section class="contact-card-section">
  <div class="contact-card">
    <p class="contact-card__eyebrow">Contacto</p>
    <h1 class="contact-card__title">Escríbenos</h1>
    <p class="contact-card__text">
      Para información general, soporte o consultas comerciales.
    </p>

    <a href={`mailto:${email}`} class="contact-card__email">
      {email}
    </a>
  </div>
</section>