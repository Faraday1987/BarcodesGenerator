---
export const prerender = false;
import "@styles/generador-excel.scss";
---

<section class="generator-bulk">
  <div class="generator-bulk__shell">
    <div class="generator-bulk__copy">
      <p class="generator-bulk__eyebrow">Generador por Excel</p>
      <h1 class="generator-bulk__title">Genera varios códigos de barras desde un archivo Excel</h1>
      <p class="generator-bulk__text">
        Sube un archivo Excel con una sola columna llamada <strong>CODIGO</strong> y debajo coloca
        un código válido por fila. El sistema generará un ZIP con todos los archivos.
      </p>

      <div class="generator-bulk__instructions">
        <h2>Cómo debe ir el Excel</h2>

        <div class="generator-bulk__card">
          <p>La primera columna debe llamarse exactamente:</p>
          <pre>CODIGO</pre>

          <p>Debajo, un código por fila:</p>
          <pre>CODIGO
7501031311309
7501031311316
7501031311323</pre>
        </div>

        <div class="generator-bulk__notes">
          <article>
            <h3>Formato correcto</h3>
            <p>
              Usa una sola columna. No mezcles nombres, descripciones ni otras columnas adicionales.
            </p>
          </article>

          <article>
            <h3>Google Sheets</h3>
            <p>
              Antes de pegar los códigos, selecciona la columna y usa:
              <strong>Formato → Número → Texto sin formato</strong>.
            </p>
            <p>
              Después pega los valores para evitar que se alteren ceros iniciales.
            </p>
          </article>

          <article>
            <h3>Tipos válidos</h3>
            <p>EAN13 = 13 dígitos</p>
            <p>GTIN-14 = 14 dígitos</p>
            <p>UPC-A = 12 dígitos</p>
          </article>
        </div>

        <div class="generator-bulk__examples">
          <h2>Descargar ejemplos</h2>
          <div class="generator-bulk__downloads">
            <a href="/upca.xlsx" class="generator-button generator-button--ghost" download>
              Ejemplo UPC-A
            </a>
            <a href="/ean13.xlsx" class="generator-button generator-button--ghost" download>
              Ejemplo EAN13
            </a>
            <a href="/gtin14.xlsx" class="generator-button generator-button--ghost" download>
              Ejemplo GTIN-14
            </a>
          </div>
        </div>
      </div>
    </div>

    <div class="generator-bulk__panel">
      <div class="generator-options">
        <h2>Opciones</h2>

        <div class="generator-options__grid">
          <label class="generator-field">
            <span>Width</span>
            <input type="number" id="opt-width" value="2" min="1" step="0.5" />
          </label>

          <label class="generator-field">
            <span>Height</span>
            <input type="number" id="opt-height" value="100" min="40" />
          </label>

          <label class="generator-field">
            <span>Margin</span>
            <input type="number" id="opt-margin" value="10" min="0" />
          </label>

          <label class="generator-field">
            <span>Background</span>
            <input type="color" id="opt-background" value="#ffffff" />
          </label>

          <label class="generator-field">
            <span>Line color</span>
            <input type="color" id="opt-lineColor" value="#000000" />
          </label>

          <label class="generator-check">
            <input type="checkbox" id="opt-displayValue" checked />
            <span>Mostrar valor</span>
          </label>
        </div>
      </div>

      <form id="excelForm" class="generator-form">
        <label class="generator-field">
          <span>Tipo de código</span>
          <select name="tipo" required>
            <option value="ean13">EAN13</option>
            <option value="gtin14">GTIN-14</option>
            <option value="upc">UPC-A</option>
          </select>
        </label>

        <label class="generator-field">
          <span>Archivo Excel</span>
          <input type="file" name="archivo" accept=".xlsx,.xls" required />
        </label>

        <button type="submit" class="generator-button--primary">Generar ZIP</button>
        <p id="excelStatus" class="generator-status" aria-live="polite"></p>
      </form>
    </div>
  </div>
</section>

<script>
  const excelForm = document.getElementById("excelForm");
  const excelStatus = document.getElementById("excelStatus");

  function getSharedOptions() {
    const width = document.getElementById("opt-width");
    const height = document.getElementById("opt-height");
    const margin = document.getElementById("opt-margin");
    const background = document.getElementById("opt-background");
    const lineColor = document.getElementById("opt-lineColor");
    const displayValue = document.getElementById("opt-displayValue");

    return {
      width: width?.value ?? "2",
      height: height?.value ?? "100",
      margin: margin?.value ?? "10",
      background: background?.value ?? "#ffffff",
      lineColor: lineColor?.value ?? "#000000",
      displayValue: displayValue?.checked ? "true" : "false"
    };
  }

  excelForm?.addEventListener("submit", async (event) => {
    event.preventDefault();

    const formData = new FormData(excelForm);
    const options = getSharedOptions();

    Object.entries(options).forEach(([key, value]) => {
      formData.append(key, value);
    });

    if (excelStatus) excelStatus.textContent = "Procesando archivo...";

    try {
      const response = await fetch("/api/generar-codigos", {
        method: "POST",
        body: formData
      });

      if (!response.ok) {
        let message = "Ocurrió un error al generar los códigos.";

        try {
          const errorData = await response.json();
          if (errorData?.error) message = errorData.error;
        } catch {}

        throw new Error(message);
      }

      const tipo = formData.get("tipo") || "codigos";
      const blob = await response.blob();
      const url = URL.createObjectURL(blob);

      const a = document.createElement("a");
      a.href = url;
      a.download = `codigos-${tipo}.zip`;
      document.body.appendChild(a);
      a.click();
      a.remove();

      URL.revokeObjectURL(url);

      if (excelStatus) excelStatus.textContent = "ZIP generado correctamente.";
    } catch (error) {
      if (excelStatus) {
        excelStatus.textContent =
          error instanceof Error ? error.message : "Error inesperado.";
      }
    }
  });
</script>