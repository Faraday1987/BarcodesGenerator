---
import Layout from '@layouts/Layout.astro';
import { locales, type Locale } from '@i18n/config';
import { t } from '@i18n/t';
import BarcodeGenerator from '@src/components/BarcodeGenerator.astro';

export function getStaticPaths() {
  return locales.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Locale };
const i18n = t(lang);
---

<Layout
  title="Generador de códigos de barras"
  description="Genera códigos EAN13, GTIN-14 y UPC-A desde Excel y descárgalos en SVG."
  keywords={i18n.siteinfo.keywords}
  lang={lang}
>
<BarcodeGenerator />
</Layout>